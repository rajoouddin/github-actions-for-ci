    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "html-webpack-inject-attributes-plugin": "^1.0.6",
    "html-webpack-plugin": "^5.6.6",
    "html-webpack-tags-plugin": "^3.0.2",
    "prettier": "^3.8.1",
    "vitest": "^4.1.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "node-forge": "^1.4.0"
  },
